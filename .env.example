TELEGRAM_BOT_TOKEN=your_bot_token_here
GEMINI_API_KEY=your_gemini_api_key_here
AI_MODEL=google-gla:gemini-flash-lite-latest
# SUMMARIZER_MODEL=google-gla:gemini-2.0-flash  # defaults to AI_MODEL
# CHAT_MODEL=                                    # defaults to AI_MODEL
# CORRECTOR_MODEL=                               # defaults to AI_MODEL
# PROMPT_ENGINEER_MODEL=                         # defaults to AI_MODEL
WHISPER_MODEL=base  # options: tiny, base, small, medium, large-v3
POLL_INTERVAL_SECONDS=3600
ADMIN_USER_ID=  # Your Telegram user ID (find via @userinfobot)
TRANSCRIBER=whisper  # options: whisper, groq
GROQ_API_KEY=  # Required when TRANSCRIBER=groq
